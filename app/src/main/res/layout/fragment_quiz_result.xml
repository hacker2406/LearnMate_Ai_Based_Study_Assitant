<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F6">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── RESULT HEADER CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <!-- Score emoji -->
                    <TextView
                        android:id="@+id/tvScoreEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎉"
                        android:textSize="56sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quiz Complete!"
                        android:textColor="#1F1F2E"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                    <!-- Score display -->
                    <TextView
                        android:id="@+id/tvFinalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 / 5"
                        android:textColor="#7C3AED"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="correct answers"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>

                    <!-- XP earned -->
                    <TextView
                        android:id="@+id/tvXpEarned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ +40 XP earned!"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_gradient"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:layout_marginTop="16dp"/>

                    <!-- Topic -->
                    <TextView
                        android:id="@+id/tvResultTopic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Topic: Photosynthesis"
                        android:textColor="#9CA3AF"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── PERFORMANCE CARD ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PERFORMANCE"
                        android:textColor="#374151"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <ProgressBar
                        android:id="@+id/scoreProgressBar"
                        style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#7C3AED"
                        android:progressBackgroundTint="#EDE9FE"/>

                    <TextView
                        android:id="@+id/tvPerformanceLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Great job! 🌟"
                        android:textColor="#7C3AED"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── ACTION BUTTONS ── -->
            <TextView
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_gradient"
                android:gravity="center"
                android:text="🔄  Play Again"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btnBackHome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_tool_card"
                android:gravity="center"
                android:text="🏠  Back to Home"
                android:textColor="#7C3AED"
                android:textSize="15sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>