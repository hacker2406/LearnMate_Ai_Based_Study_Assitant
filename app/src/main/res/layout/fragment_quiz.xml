<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F6">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/quizHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_header"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUIZ"
            android:textColor="#CCEEFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Yourself"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠"
                android:textSize="32sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── SCROLLABLE CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/quizHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── SOURCE SELECTOR ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUIZ SOURCE"
                android:textColor="#374151"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/sourceTopicBtn"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="📖 Topic"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_tab_active"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/sourceNoteBtn"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="📝 From Notes"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#9CA3AF"
                    android:background="@drawable/bg_tab_container"
                    android:layout_marginStart="6dp"/>

            </LinearLayout>

            <!-- ── TOPIC INPUT (shown when Topic selected) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/topicInputCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENTER TOPIC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.08"/>

                    <EditText
                        android:id="@+id/etTopic"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="e.g. Photosynthesis, Linked Lists..."
                        android:textSize="14sp"
                        android:textColor="#1F1F2E"
                        android:textColorHint="#D1D5DB"
                        android:background="@drawable/bg_field"
                        android:paddingHorizontal="14dp"
                        android:inputType="textCapSentences"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── NOTES PICKER (shown when Notes selected) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/notesPickerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT A NOTE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.08"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvNotesPicker"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── NUMBER OF QUESTIONS ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NUMBER OF QUESTIONS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:letterSpacing="0.08"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:id="@+id/num5"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="5"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_tab_active"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/num10"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="10"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#9CA3AF"
                            android:background="@drawable/bg_tab_container"
                            android:layout_marginHorizontal="3dp"/>

                        <TextView
                            android:id="@+id/num15"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="15"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#9CA3AF"
                            android:background="@drawable/bg_tab_container"
                            android:layout_marginStart="6dp"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── ERROR TEXT ── -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#DC2626"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"/>

            <!-- ── GENERATE BUTTON ── -->
            <TextView
                android:id="@+id/btnGenerate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_gradient"
                android:gravity="center"
                android:text="🧠  Generate Quiz"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!-- ── LOADING ── -->
            <LinearLayout
                android:id="@+id/loadingView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="#7C3AED"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generating your quiz..."
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>