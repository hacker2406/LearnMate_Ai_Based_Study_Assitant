<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Subtle radial glow behind logo -->
    <View
        android:id="@+id/logoGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_logo_glow"
        android:alpha="0.5"
        app:layout_constraintTop_toTopOf="@id/centerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/centerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="160dp"
            android:layout_height="152dp"
            android:contentDescription="LearnMate Logo"
            android:src="@drawable/learnmate_brain"
            android:elevation="8dp"/>

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to"
            android:textSize="16sp"
            android:textColor="#CCFFFFFF"
            android:letterSpacing="0.12"
            android:gravity="center"
            android:layout_marginTop="28dp"/>

        <!-- Gradient text workaround: use a shaped background clip via code,
             or use the simple solid color below and apply gradient in SplashFragment.kt -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LearnMate"
            android:textSize="42sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:letterSpacing="-0.02"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:background="@drawable/divider_gradient"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Study Buddy"
            android:textSize="15sp"
            android:textColor="#CCFFFFFF"
            android:letterSpacing="0.08"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Loading dots at the bottom -->
    <LinearLayout
        android:id="@+id/loadingDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot"
            android:layout_marginHorizontal="4dp"
            android:alpha="1.0"/>

        <View
            android:id="@+id/dot2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot"
            android:layout_marginHorizontal="4dp"
            android:alpha="0.5"/>

        <View
            android:id="@+id/dot3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot"
            android:layout_marginHorizontal="4dp"
            android:alpha="0.25"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>