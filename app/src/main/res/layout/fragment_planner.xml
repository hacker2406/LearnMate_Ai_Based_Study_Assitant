<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF0F6">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:id="@+id/plannerHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_header"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY PLANNER"
            android:textColor="#CCEEFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTaskCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 tasks"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:id="@+id/tvCompletedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 completed"
                    android:textColor="#CCEEFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="32sp"/>

        </LinearLayout>

        <!-- Progress bar for tasks -->
        <ProgressBar
            android:id="@+id/taskProgressBar"
            style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="14dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FDE68A"
            android:progressBackgroundTint="#4466AA"/>

    </LinearLayout>

    <!-- ── FILTER CHIPS ── -->
    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/plannerHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_tab_active"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/filterToday"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Today"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_tab_container"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/filterPending"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Pending"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_tab_container"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/filterDone"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Done"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_tab_container"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ── EMPTY STATE ── -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="64sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tasks yet"
            android:textColor="#1F1F2E"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to add your first task"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- ── RECYCLERVIEW ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTasks"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/filterScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── FAB ── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="#FFFFFF"
        android:backgroundTint="#7C3AED"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>